+// acquireProcessor attempts to claim the single-processor slot for bulkID. It
+// returns a session id on success, or ErrConcurrentProcessor if another
+// processor is active (or its lock has not yet timed out).
+func (s *Service) acquireProcessor(ctx context.Context, txm database.TxManager, bulkID uuid.UUID) (uuid.UUID, error) {
+	sessionID := s.idgen.New()
+	var acquired bool
+	err := txm.WithTenant(ctx, func(ctx context.Context, db database.TenantDB) error {
+		var id uuid.UUID
+		err := db.QueryRow(ctx,
+			`UPDATE bulk_operations
+			    SET processor_id = $2, processor_started_at = now()
+			  WHERE id = $1
+			    AND (processor_id IS NULL OR processor_started_at < now() - $3::interval)
+			RETURNING processor_id`,
+			bulkID, sessionID, lockTimeout.String()).Scan(&id)
+		if err != nil {
+			if errors.Is(err, pgx.ErrNoRows) {
+				return nil
+			}
+			return kerr.Wrapf(err, "bulk.acquireProcessor", "claim lock for bulk %s", bulkID)
+		}
+		acquired = true
+		return nil
+	})
+	if err != nil {
+		return uuid.Nil, err
+	}
+	if !acquired {
+		return uuid.Nil, ErrConcurrentProcessor
+	}
+	return sessionID, nil
+}
+
+// releaseProcessor clears the single-processor slot, but only if it is still
+// held by sessionID (defensive against a timeout/reclaim race).
+func (s *Service) releaseProcessor(ctx context.Context, txm database.TxManager, bulkID, sessionID uuid.UUID) {
+	err := txm.WithTenant(ctx, func(ctx context.Context, db database.TenantDB) error {
+		_, err := db.Exec(ctx,
+			`UPDATE bulk_operations
+			    SET processor_id = NULL, processor_started_at = NULL
+			  WHERE id = $1 AND processor_id = $2`,
+			bulkID, sessionID)
+		return err
+	})
+	if err != nil && s.log != nil {
+		s.log.ErrorContext(ctx, "bulk processor lock release failed", "bulk_id", bulkID, "error", err)
+	}
+}
