#!/bin/sh
# wowapi pre-push hook (installed via `make hooks` → core.hooksPath=.githooks).
# The fuller gate before code leaves the machine: go vet, lint of changed code,
# unit tests, and a go.mod/go.sum tidy check. Bypass: git push --no-verify.
# (The authoritative DB-backed gate runs in CI via `make ci-container`.)
set -e

# Capture the refs being pushed BEFORE anything else can touch stdin.
# Format per line: <local ref> <local sha> <remote ref> <remote sha>
push_refs=$(cat)

# Secret scan of the outgoing commits — mirrors CI's blocking gitleaks job
# (same detect + --no-merges --first-parent range semantics, same .gitleaksignore),
# so a leak is caught here instead of failing the pipeline after push.
if command -v gitleaks >/dev/null 2>&1; then
	zero=0000000000000000000000000000000000000000
	printf '%s\n' "$push_refs" | while read -r local_ref local_sha remote_ref remote_sha; do
		[ -z "$local_sha" ] || [ "$local_sha" = "$zero" ] && continue # branch deletion
		if [ "$remote_sha" = "$zero" ]; then
			# New remote branch: scan everything not already on origin/main.
			base=$(git merge-base origin/main "$local_sha" 2>/dev/null || true)
		else
			base="$remote_sha"
		fi
		if [ -n "$base" ]; then
			echo "pre-push: gitleaks ($base..$local_sha)"
			gitleaks detect --redact --exit-code=1 \
				--log-opts="--no-merges --first-parent $base..$local_sha" || {
				echo "pre-push: FAIL — gitleaks found a potential secret in the outgoing commits."
				echo "  False positive? Add its fingerprint to .gitleaksignore (see existing entries)."
				exit 1
			}
		fi
	done || exit 1
else
	echo "pre-push: gitleaks not found — 'brew install gitleaks'. Skipping secret scan (CI will still block)."
fi

echo "pre-push: go vet ./..."
go vet ./...

if command -v golangci-lint >/dev/null 2>&1; then
	base=$(git rev-parse --verify -q origin/main || git rev-parse --verify -q HEAD~1 || true)
	if [ -n "$base" ]; then
		echo "pre-push: golangci-lint (changed code since $base)"
		golangci-lint run --new-from-merge-base="$base" ./...
	fi
else
	echo "pre-push: golangci-lint not found — run 'make tools'. Skipping lint."
fi

# DB-gated tests must RUN here, not silently self-skip (W01-E01-S003 / FBL-07):
# a green hook that never exercised the DB-backed tests is a misleading signal.
# The DSN falls back to the compose-stack default (mirrors the Makefile's
# TEST_DSN); WOWAPI_REQUIRE_DB=1 turns a missing/unreachable DB into a loud
# test FAILURE (testkit.RequireDB) instead of a silent skip.
# Explicit, visible opt-out for machines without a local DB:
#   WOWAPI_PREPUSH_SKIP_DB=1 git push   (DB tests skip — loudly announced)
if [ -n "${WOWAPI_PREPUSH_SKIP_DB:-}" ]; then
	echo "pre-push: WARNING — WOWAPI_PREPUSH_SKIP_DB is set: DB-gated tests will SKIP, not run."
	echo "pre-push: go test ./... (unit only — DB-gated tests skipped by explicit opt-out)"
	go test ./...
else
	echo "pre-push: go test ./... (DB-gated tests REQUIRED — no silent skip)"
	if ! DATABASE_URL="${DATABASE_URL:-postgres://wowapi:wowapi-local-only@localhost:5432/wowapi?sslmode=disable}" \
		WOWAPI_REQUIRE_DB=1 go test ./...; then
		echo ""
		echo "pre-push: FAIL — tests failed, or DB-gated tests could not run."
		echo "  This hook requires the DB-backed tests to actually run (no silent skip)."
		echo "    - start the local database:  make up   (or export DATABASE_URL)"
		echo "    - knowingly skip DB tests:   WOWAPI_PREPUSH_SKIP_DB=1 git push"
		echo "    - bypass every hook check:   git push --no-verify"
		exit 1
	fi
fi

echo "pre-push: go.mod/go.sum tidy check"
cp go.mod go.mod.hook.bak; cp go.sum go.sum.hook.bak
go mod tidy
if ! diff -q go.mod go.mod.hook.bak >/dev/null 2>&1 || ! diff -q go.sum go.sum.hook.bak >/dev/null 2>&1; then
	mv go.mod.hook.bak go.mod; mv go.sum.hook.bak go.sum
	echo "pre-push: go.mod/go.sum not tidy — run 'make tidy' and commit."
	exit 1
fi
rm -f go.mod.hook.bak go.sum.hook.bak

echo "pre-push: OK"
