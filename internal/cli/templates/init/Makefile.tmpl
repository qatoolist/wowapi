.PHONY: build test lint migrate-up migrate-down

build:
	go build -o bin/api ./cmd/api
	go build -o bin/worker ./cmd/worker
	go build -o bin/migrate ./cmd/migrate

test:
	go test ./...

lint:
	go vet ./...

migrate-up:
	go run ./cmd/migrate up

# migrate-down is a FULL reset to version 0 (not a stepwise rollback). The runner
# refuses to run it unless the environment is local/dev — production schema changes
# use forward (expand-contract) migrations. Intended for local teardown only.
migrate-down:
	go run ./cmd/migrate down
