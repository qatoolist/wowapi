{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/qatoolist/wowapi/ci/release-gates.schema.json",
  "title": "wowapi exact-commit release gate manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "completed_wave", "gates"],
  "properties": {
    "schema_version": {"const": 2},
    "completed_wave": {"type": "integer", "minimum": 0},
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "command", "owner", "required_from_wave", "timeout_minutes", "evidence_artifact"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "command": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "required_from_wave": {"type": "integer", "minimum": 0},
          "timeout_minutes": {"type": "integer", "minimum": 1, "maximum": 120},
          "evidence_artifact": {"type": "string", "pattern": "^[a-zA-Z0-9._/-]+$"},
          "requires_services": {"type": "boolean"},
          "security_results": {
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["secret", "reachable-vulnerability", "disallowed-license", "dependency", "workflow", "critical-high-config"]}
          }
        }
      }
    }
  }
}
