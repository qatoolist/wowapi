// Package appcfg is {{.Name}}'s product-owned configuration (D-0002): the
// framework config plus this product's module namespaces and any
// product-specific fields. config.Framework is embedded, so its fields
// (Environment, HTTP, Log, DB) are read directly; each module receives its
// modules.<name>.* subtree via Config.Modules.
package appcfg

import (
	"errors"
	"fmt"
	"os"
	"time"

	"{{.FrameworkModule}}/adapters/secrets/envprovider"
	"{{.FrameworkModule}}/kernel/config"
	"{{.FrameworkModule}}/kernel/i18n"

	"{{.Module}}/internal/i18n/catalogs"
)

// Config is {{.Name}}'s composed configuration. Add product-specific top-level
// config fields here; they load from the same layered sources.
type Config struct {
	config.Framework
	// Auth holds product-owned authentication config. When Auth.OIDC.Issuer is
	// set, cmd/api wires the OIDC/JWT bearer authenticator as the user leg of the
	// composite; left empty, that leg stays DenyAll (deny-by-default) so only API
	// keys authenticate.
	Auth AuthConfig `conf:"auth" json:"auth"`
	// Storage configures the S3/MinIO object-storage adapter
	// ({{.FrameworkModule}}/adapters/storage/s3). When Storage.Endpoint
	// is set, cmd/api and cmd/worker wire the adapter as kernel Deps.Storage;
	// left unset, Deps.Storage stays nil and app.Boot fails closed if a module
	// registers a document class.
	Storage StorageConfig `conf:"storage" json:"storage"`
	// I18n configures the message-catalog sources loaded before boot completes
	// (localization; framework GAP-001B). The zero value is valid: with no config
	// section, DefaultLocale defaults to "en" and the locales/ directory is loaded
	// as a sanctioned framework-override source, so a product can add translation
	// files with no code change. cmd/api, cmd/worker, AND cmd/migrate load the
	// SAME sources through app.Boot(app.WithI18nLayers(...)).
	I18n I18nConfig `conf:"i18n" json:"i18n"`
	// Modules carries each registered module's modules.<name>.* namespace,
	// passed to app.Boot so modules receive only their own config.
	Modules config.Namespaces `conf:"modules"`
}

// I18nConfig configures localization catalog loading. A product edits configs/*.yaml
// (the i18n: section) or these defaults; the generated binaries turn it into
// precedence-ordered loader layers on top of the framework's embedded English
// defaults. Layers, in order: product locales/ files (YAML+JSON, may override
// kernel.* framework strings) then compiled Go bundles (internal/i18n/catalogs).
type I18nConfig struct {
	// DefaultLocale is the fallback locale; every key resolves here when a
	// requested locale lacks it. Defaults to "en".
	DefaultLocale string `conf:"default_locale" default:"en" json:"default_locale" doc:"fallback locale for message lookups"`
	// SupportedLocales is the set of locales this product ships (drives coverage
	// checks in 'wowapi i18n validate'). Defaults to [en].
	SupportedLocales []string `conf:"supported_locales" json:"supported_locales" doc:"locales this product supports"`
	// LocalesDir is the product-local catalog directory (YAML + JSON), loaded as a
	// sanctioned framework-override source. Defaults to "locales".
	LocalesDir string `conf:"locales_dir" default:"locales" json:"locales_dir" doc:"directory of product locale catalogs"`
	// GoBundles enables the compiled Go catalog layer (internal/i18n/catalogs).
	// Defaults true so the scaffolded sample bundle loads; set false to disable.
	GoBundles bool `conf:"go_bundles" default:"true" json:"go_bundles" doc:"load the compiled Go catalog bundles in internal/i18n/catalogs"`
}

// DefaultLocaleOrEn returns the configured default locale or "en".
func (c I18nConfig) DefaultLocaleOrEn() string {
	if c.DefaultLocale == "" {
		return i18n.DefaultLocale
	}
	return c.DefaultLocale
}

// Layers builds the product's i18n source layers (framework-override locales/
// files + optional compiled Go bundles) for app.Boot(app.WithI18nLayers(...)).
// The framework's embedded English defaults are always installed by the kernel
// registry and sit beneath these layers, so this returns only the product's
// additions. Called identically by cmd/api, cmd/worker, and cmd/migrate so all
// three share one catalog lifecycle.
func (c I18nConfig) Layers() ([]i18n.Layer, error) {
	dir := c.LocalesDir
	if dir == "" {
		dir = "locales"
	}
	specs := []i18n.SourceSpec{
		{Kind: i18n.KindFrameworkDefaults, Enabled: true},
		{
			Kind:               i18n.KindFS,
			Path:               dir,
			Formats:            []string{"yaml", "json"},
			OverridesFramework: true,
			Enabled:            true,
		},
		{
			Kind:    i18n.KindGo,
			Enabled: c.GoBundles,
			Go:      catalogs.Bundles(),
		},
	}
	return i18n.BuildLayers(os.DirFS("."), specs)
}

// Validate delegates to the embedded Framework validation and adds the
// product-owned sections (ARCH-10 composition contract: a product Config that
// shadows the promoted Framework.Validate MUST delegate to it).
func (c Config) Validate() error {
	return errors.Join(c.Framework.Validate(), c.Storage.Validate())
}

// AuthConfig groups {{.Name}}'s authentication settings.
type AuthConfig struct {
	OIDC OIDCConfig `conf:"oidc" json:"oidc"`
}

// OIDCConfig configures the OIDC/JWT bearer authenticator (kernel/auth). Set
// Issuer (and normally Audience) to enable the user auth leg. JWKSURI is
// optional: when empty it is discovered from the issuer's
// /.well-known/openid-configuration document.
type OIDCConfig struct {
	Issuer   string `conf:"issuer" json:"issuer" doc:"OIDC issuer (iss); enables the user auth leg when set"`
	Audience string `conf:"audience" json:"audience" doc:"expected token audience (aud)"`
	JWKSURI  string `conf:"jwks_uri" json:"jwks_uri" doc:"JWKS endpoint; discovered from the issuer when empty"`
}

// Presign TTL bounds: presigned URLs are deliberately short-lived; anything
// under a minute races slow uploads, anything over an hour stops being
// "short-lived".
const (
	MinPresignTTL = time.Minute
	MaxPresignTTL = time.Hour
)

// StorageConfig configures the S3/MinIO object-storage adapter backing the
// document framework. Endpoint empty = object storage disabled (the zero
// value validates). Credentials are secretref-only Secret fields — never
// inline values in overlays.
type StorageConfig struct {
	Endpoint     string        `conf:"endpoint" json:"endpoint" doc:"S3-compatible endpoint (host:port, or http(s)://host:port); empty disables object storage"`
	Bucket       string        `conf:"bucket" json:"bucket" doc:"bucket holding all document objects (keys are tenant-prefixed by the kernel)"`
	Region       string        `conf:"region" json:"region" doc:"bucket region; empty is fine for MinIO"`
	AccessKey    config.Secret `conf:"access_key" json:"access_key" doc:"access key as a secretref:// reference (e.g. secretref://env/S3_ACCESS_KEY)"`
	SecretKey    config.Secret `conf:"secret_key" json:"secret_key" doc:"secret key as a secretref:// reference (e.g. secretref://env/S3_SECRET_KEY)"`
	UseSSL       bool          `conf:"use_ssl" json:"use_ssl" doc:"connect over TLS; ignored when the endpoint carries an explicit http:// or https:// scheme"`
	PresignTTL   time.Duration `conf:"presign_ttl" default:"15m" json:"presign_ttl" doc:"default AND upper bound for presigned URL validity (1m..1h); the adapter clamps longer requests down to it"`
	CreateBucket bool          `conf:"create_bucket" json:"create_bucket" doc:"create the bucket at boot when absent — local/dev overlays only; production buckets are provisioned, not conjured"`
}

// Enabled reports whether object storage is configured at all.
func (s StorageConfig) Enabled() bool { return s.Endpoint != "" }

// Validate checks the storage section. Like Framework.Validate it returns ALL
// problems joined. The zero value (storage disabled) is valid.
func (s StorageConfig) Validate() error {
	if !s.Enabled() {
		return nil
	}
	var errs []error
	add := func(format string, args ...any) { errs = append(errs, fmt.Errorf(format, args...)) }

	if s.Bucket == "" {
		add("storage.bucket: required when storage.endpoint is set")
	}
	if s.AccessKey.IsZero() {
		add("storage.access_key: required when storage.endpoint is set (use a secretref:// reference)")
	}
	if s.SecretKey.IsZero() {
		add("storage.secret_key: required when storage.endpoint is set (use a secretref:// reference)")
	}
	if s.PresignTTL < MinPresignTTL || s.PresignTTL > MaxPresignTTL {
		add("storage.presign_ttl: %s out of bounds (%s..%s — presigned URLs must stay short-lived)",
			s.PresignTTL, MinPresignTTL, MaxPresignTTL)
	}
	return errors.Join(errs...)
}

// Load reads the layered configuration in precedence order: configs/base.yaml,
// then the configs/<APP_ENV>.yaml overlay (when APP_ENV is set), then the
// WOWAPI__ environment layer, with secretref:// values resolved via the env
// secret provider. It returns the composed config and its redacted fingerprint.
func Load() (Config, config.Fingerprint, error) {
	opts := config.Options{
		EnvPrefix: "WOWAPI__",
		Secrets:   envprovider.New(),
	}
	if _, err := os.Stat("configs/base.yaml"); err == nil {
		opts.BaseFile = "configs/base.yaml"
	}
	if env := os.Getenv("APP_ENV"); env != "" {
		opts.EnvFile = "configs/" + env + ".yaml"
	}
	return config.Load[Config](opts)
}
