#!/bin/sh
# wowapi pre-commit hook (installed via `make hooks` → core.hooksPath=.githooks).
# Fast checks on the Go changes being committed: formatting (gofumpt + goimports)
# and a lint of only the CHANGED code. Bypass in an emergency: git commit --no-verify
set -e

# Secret scan of the staged diff (ALL file types — docs/evidence files leak too,
# not just code). Mirrors CI's blocking gitleaks job; honors .gitleaksignore.
if command -v gitleaks >/dev/null 2>&1; then
	gitleaks git --staged --pre-commit --redact --exit-code=1 >/dev/null 2>&1 || {
		echo "pre-commit: gitleaks found a potential secret in the staged changes:"
		gitleaks git --staged --pre-commit --redact --exit-code=1 -v || true
		echo "pre-commit: false positive? Add its fingerprint to .gitleaksignore (see existing entries)."
		exit 1
	}
else
	echo "pre-commit: gitleaks not found — 'brew install gitleaks'. Skipping secret scan (CI will still block)."
fi

changed=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.go$' || true)
[ -z "$changed" ] && exit 0

if ! command -v golangci-lint >/dev/null 2>&1; then
	echo "pre-commit: golangci-lint not found — run 'make tools'. Skipping (commit allowed)."
	exit 0
fi

# 1. Formatting: gofumpt + goimports (golangci-lint bundles them).
drift=$(golangci-lint fmt --diff 2>/dev/null || true)
if [ -n "$drift" ]; then
	echo "pre-commit: formatting needed — run 'make fmt', then re-stage. Offending files:"
	printf '%s\n' "$drift" | grep -E '^(diff|\+\+\+) ' | head
	exit 1
fi

# 2. Lint the changed code only (the pre-existing backlog is not enforced here).
base=$(git rev-parse --verify -q origin/main || git rev-parse --verify -q HEAD~1 || true)
if [ -n "$base" ]; then
	golangci-lint run --new-from-merge-base="$base" ./... || {
		echo "pre-commit: fix the new lint issues above, or 'git commit --no-verify' to skip."
		exit 1
	}
fi

# Installed by code-review-graph. Remove this block to disable pre-commit graph checks.
if command -v code-review-graph >/dev/null 2>&1; then
	code-review-graph update || true
	code-review-graph detect-changes --brief || true
fi
