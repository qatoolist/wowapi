// Command api is the HTTP API server for {{.Name}}.
package main

import (
	"context"
	"fmt"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"github.com/qatoolist/wowapi/adapters/auth/pgprincipal"
	promadapter "github.com/qatoolist/wowapi/adapters/metrics/prometheus"
	oteladapter "github.com/qatoolist/wowapi/adapters/tracing/otel"
	"github.com/qatoolist/wowapi/app"
	"github.com/qatoolist/wowapi/kernel/apikey"
	kaudit "github.com/qatoolist/wowapi/kernel/audit"
	kauth "github.com/qatoolist/wowapi/kernel/auth"
	"github.com/qatoolist/wowapi/kernel"
	"github.com/qatoolist/wowapi/kernel/database"
	"github.com/qatoolist/wowapi/kernel/httpx"
	"github.com/qatoolist/wowapi/kernel/logging"
	"github.com/qatoolist/wowapi/kernel/model"
	"github.com/qatoolist/wowapi/kernel/observability"

	"{{.Module}}/internal/appcfg"
	"{{.Module}}/internal/wire"
)

func main() {
	ctx, cancel := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)
	defer cancel()
	if err := run(ctx); err != nil {
		fmt.Fprintf(os.Stderr, "{{.Name}}: api: %v\n", err)
		os.Exit(1)
	}
}

func run(ctx context.Context) error {
	cfg, fp, err := appcfg.Load()
	if err != nil {
		return fmt.Errorf("config: %w", err)
	}

	log, err := logging.New(os.Stderr, cfg.Log)
	if err != nil {
		return fmt.Errorf("logger: %w", err)
	}
	logging.LogStartup(log, "api", cfg.Environment, fp)

	// Metrics: a real Prometheus adapter is wired so the RED middleware, kernel
	// components (webhook breaker, scheduler lag, DLQ depth, rate-limit drops),
	// and the config-fingerprint info gauge actually export series at /metrics.
	metrics := promadapter.New()
	// Export the effective config fingerprint as an info gauge so a monitor can
	// alert on config drift without a redeploy (roadmap O4/CA-1).
	metrics.SetGauge("wowapi_config_fingerprint_info", 1,
		map[string]string{"fingerprint": fp.Short()})

	// Tracing: OFF (zero-cost NoOp) unless telemetry.trace_sample_ratio > 0. When
	// enabled, export spans to OTEL_EXPORTER_OTLP_ENDPOINT (roadmap O1/CA-2). A
	// failure to build the exporter degrades to NoOp rather than blocking startup.
	tracer := observability.NoOpTracer
	if cfg.Telemetry.TraceSampleRatio > 0 {
		ot, terr := oteladapter.NewOTLP(ctx, cfg.Telemetry.TraceSampleRatio)
		if terr != nil {
			log.WarnContext(ctx, "tracing disabled: OTLP exporter init failed", "err", terr)
		} else {
			tracer = ot
			defer func() { _ = ot.Shutdown(context.WithoutCancel(ctx)) }()
		}
	}

	// Resolve the runtime DSN: prefer a resolved secretref, then DATABASE_URL.
	dsn := cfg.DB.DSN.Reveal()
	if dsn == "" {
		dsn = os.Getenv("DATABASE_URL")
	}
	if dsn == "" {
		return fmt.Errorf("db.dsn required: set db.dsn in configs/ via secretref://env/DATABASE_URL, or export DATABASE_URL")
	}

	// Build the runtime pool as app_rt with RLS enforcement (SEC-11/SEC-12).
	pool, err := database.NewPool(ctx, dsn, cfg.DB,
		database.WithSetRole("app_rt"),
		database.WithConnRLSGuard(),
	)
	if err != nil {
		return fmt.Errorf("db pool: %w", err)
	}
	defer pool.Close()

	txm := database.NewManager(pool, cfg.DB,
		database.WithRole("app_rt"),
		database.WithRLSGuard(),
	)

	// Platform pool (app_platform): cross-tenant API-key verification (the tenant is
	// unknown pre-auth) and any kernel cross-tenant work. It MUST use a dedicated
	// app_platform login (db.platform_dsn), NOT the runtime DSN + SET ROLE app_platform:
	// that would require app_rt to be a (cluster-global) member of app_platform and
	// collapse runtime/platform privilege separation on an internet-facing process
	// (CF-1). Fail closed. Built BEFORE Boot and wired into the kernel so app.Boot's
	// RLS-enforcement check (M3) covers it as a framework-level backstop; the
	// per-connection WithConnRLSGuard is defense-in-depth on top.
	platformDSN := cfg.DB.PlatformDSN.Reveal()
	if platformDSN == "" {
		return fmt.Errorf("db.platform_dsn is required: the platform pool needs a dedicated app_platform " +
			"login (set db.platform_dsn, e.g. secretref://env/PLATFORM_URL). Reusing the runtime DSN would " +
			"require app_rt to be a member of app_platform and defeat runtime/platform privilege separation")
	}
	platformPool, err := database.NewPool(ctx, platformDSN, cfg.DB,
		database.WithSetRole("app_platform"),
		database.WithConnRLSGuard(),
	)
	if err != nil {
		return fmt.Errorf("db pool (platform): %w", err)
	}
	defer platformPool.Close()

	k, err := kernel.New(cfg.Framework, log, kernel.Deps{Pool: pool, Platform: platformPool, Tx: txm, Metrics: metrics, Tracer: tracer})
	if err != nil {
		return fmt.Errorf("kernel: %w", err)
	}

	a := app.New()
	a.Register(wire.Modules()...)
	// Modules receive only their own modules.<name>.* namespace.
	booted, err := a.Boot(ctx, k, cfg.Modules)
	if err != nil {
		return fmt.Errorf("boot: %w", err)
	}

	// Composite authenticator (roadmap S1/CA-2): API keys first, then your user
	// (OIDC) authenticator. API-key verification is cross-tenant (the tenant is
	// unknown pre-auth), so it runs on the app_platform pool built above.
	platformTxM := database.NewManager(platformPool, cfg.DB, database.WithRole("app_platform"))
	apiKeyAuth := apikey.NewAuthenticator(
		apikey.NewStore(model.UUIDv7(), apikey.WithAudit(kaudit.New(model.UUIDv7(), nil))),
		platformTxM,
	)

	// User (OIDC/JWT bearer) leg of the composite. It is wired only when
	// auth.oidc.issuer is configured; otherwise it stays DenyAll so non-key
	// business requests return 401 — the secure default (deny-by-default). The
	// authenticator verifies bearer JWTs against the issuer's JWKS (RS256/ES256,
	// cached) and resolves the framework principal (subject -> user, capacity
	// check) via the platform + runtime pools.
	var userAuth httpx.Authenticator = httpx.DenyAllAuthenticator{}
	if cfg.Auth.OIDC.Issuer != "" {
		jwks, jerr := kauth.NewJWKSKeySource(kauth.JWKSConfig{
			Issuer:  cfg.Auth.OIDC.Issuer,
			JWKSURI: cfg.Auth.OIDC.JWKSURI,
		})
		if jerr != nil {
			return fmt.Errorf("auth: jwks source: %w", jerr)
		}
		verifier := kauth.NewVerifier(jwks, kauth.Config{
			Issuer:   cfg.Auth.OIDC.Issuer,
			Audience: cfg.Auth.OIDC.Audience,
		})
		userAuth = kauth.NewAuthenticator(verifier, pgprincipal.New(platformTxM, txm))
	}

	// The RouteMeta permission gate is ENFORCED on every non-Public route
	// (deny-by-default: AuthN -> bind tenant/actor -> AuthZ(permission)): API keys
	// first, then the user (OIDC) leg above.
	auth := httpx.Composite(apiKeyAuth, userAuth)
	mux := booted.Router.SecureHandler(auth, booted.Kernel.Authz, booted.Kernel.Tx)

	// Health endpoints are Public infrastructure, mounted directly.
	health := app.Readiness(booted, fp, map[string]httpx.HealthCheck{
		"db": func(ctx context.Context) error { return pool.Ping(ctx) },
	})
	mux.Handle("/healthz", health.Liveness())
	mux.Handle("/readyz", health.Readiness())
	// Prometheus exposition. Mounted as Public infrastructure like the health
	// endpoints; in production restrict it to an internal listener or scrape it
	// through the reference proxy (see deployments/reference/) so it is not
	// world-readable.
	mux.Handle("/metrics", metrics.Handler())

	// Middleware chain (blueprint 07 §1 order, outermost first). SecureHeaders +
	// CORS must be OUTER to any middleware that can short-circuit a response
	// (RateLimit 429, BodyLimit 413, Timeout 503): they set headers before calling
	// next, so placing them outermost guarantees the headers are present on those
	// error responses too. In particular a browser cross-origin client that is
	// rate-limited must still receive CORS headers, or it cannot read the 429 or the
	// Retry-After. The CORS allowlist / body / timeout caps come from configs/
	// (empty allowlist = deny all cross-origin).
	mws := []httpx.Middleware{
		httpx.RequestID(),
		httpx.Recover(log),
		httpx.SecureHeaders(),
		httpx.CORS(httpx.CORSPolicy{AllowedOrigins: cfg.HTTP.CORSAllowedOrigins}),
		observability.Trace(tracer),     // OTel span per request when tracing is enabled
		observability.Requests(metrics), // RED metrics per route (exported at /metrics)
		observability.AccessLog(log),
	}
	// Rate limiting is ON by default (opt-out via http.rate_limit.disabled): an
	// in-process per-IP token bucket returning 429 + Retry-After, with drops
	// counted as rate_limit_dropped_total (roadmap S2/CA-2). It sits inner to
	// SecureHeaders/CORS (so 429s carry those headers) but outer to BodyLimit/Timeout
	// (a rejected request has no body to read and no handler work to time out). Place
	// a per-actor bucket AFTER the authz gate if you need per-principal limits.
	//
	// TRADE-OFF: because CORS is outer, an allowed-origin OPTIONS preflight is
	// answered (204) before reaching the limiter, so preflights are NOT rate-limited
	// or metered. That is deliberate — rate-limiting preflights breaks legitimate
	// browsers (every cross-origin request emits one) — but it means volumetric
	// preflight protection is an edge concern (LB/WAF + ReadHeaderTimeout), not this
	// bucket's job.
	if !cfg.HTTP.RateLimit.Disabled {
		limiter := httpx.NewTokenBucket(cfg.HTTP.RateLimit.RequestsPerSecond, cfg.HTTP.RateLimit.Burst)
		mws = append(mws, httpx.RateLimit(limiter, httpx.KeyByIP,
			httpx.OnRateLimitDrop(func(route string) {
				metrics.IncCounter("rate_limit_dropped_total", 1, map[string]string{"route": route})
			})))
	}
	mws = append(mws,
		httpx.BodyLimit(cfg.HTTP.MaxBodyBytes),
		httpx.Timeout(cfg.HTTP.RequestTimeout),
	)
	handler := httpx.Chain(mux, mws...)

	srv := &http.Server{
		Addr:              cfg.HTTP.Addr,
		Handler:           handler,
		ReadHeaderTimeout: cfg.HTTP.ReadHeaderTimeout,
	}

	return app.RunHooks(ctx, log, 30*time.Second,
		app.Hook{
			Name: "http",
			Start: func(ctx context.Context) error {
				log.InfoContext(ctx, "listening", "addr", cfg.HTTP.Addr)
				go func() {
					if err := srv.ListenAndServe(); err != nil && err != http.ErrServerClosed {
						log.ErrorContext(ctx, "http server error", "err", err)
					}
				}()
				return nil
			},
			Stop: func(ctx context.Context) error { return srv.Shutdown(ctx) },
		},
	)
}
