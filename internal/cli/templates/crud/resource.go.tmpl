// {{.ResourceTitle}}Handlers holds the collaborators every {{.Resource}} route needs.
type {{.ResourceTitle}}Handlers struct {
	tx     database.TxManager
	idgen  model.IDGen
	outbox outbox.Writer
}

// list{{.ResourceTitle}}Sort is the fixed (created_at, id) keyset order. Building it
// through the filtering allowlist gives every cursor a sort-spec signature, so a
// forged or stale cursor is rejected loudly on decode (roadmap R7) instead of
// silently mis-paging.
var list{{.ResourceTitle}}Sort = func() filtering.Sort {
	s, err := filtering.ParseSort("created_at,id", filtering.SortAllowlist{
		"created_at": {Col: "created_at"},
		"id":         {Col: "id"},
	})
	if err != nil {
		panic("{{.Resource}}: invalid keyset sort: " + err.Error())
	}
	return s
}()

// Create{{.ResourceTitle}}Request is the request contract for POST /{{.Resource}}.
// It is declared on the route's RouteMeta AND bound by httpx.ValidatedHandler,
// so struct-tag validation always runs before create executes — declaring the
// contract and wiring validation are the same act (there is no path to a
// handler that "forgot" to validate). Adjust the `validate:` tags to your
// domain rules; `required` is only the scaffold's safe starting point.
type Create{{.ResourceTitle}}Request struct {
{{- range .Fields}}
	{{.GoName}} {{.GoType}} `json:"{{.Name}}" validate:"required"`
{{- end}}
}

// Update{{.ResourceTitle}}Request is the request contract for PUT /{{.Resource}}/{id}.
type Update{{.ResourceTitle}}Request struct {
{{- range .Fields}}
	{{.GoName}} {{.GoType}} `json:"{{.Name}}" validate:"required"`
{{- end}}
}

// Register{{.ResourceTitle}}Routes wires {{.Resource}} CRUD routes into mc.
// Mutating routes declare their request contract on RouteMeta.Request and run
// through httpx.ValidatedHandler; with security.enforce_route_contracts
// enabled, a mutating route missing both Request and NoRequestBody fails boot.
func Register{{.ResourceTitle}}Routes(mc module.Context) {
	h := &{{.ResourceTitle}}Handlers{tx: mc.Tx(), idgen: mc.IDGen(), outbox: mc.Outbox()}
	r := mc.Routes()
	v := mc.Validator()
	// 1<<20 (1 MiB) mirrors the default http.max_body_bytes edge guardrail;
	// keep the two in sync if your product raises the config value.
	r.Handle("POST", "/{{.Resource}}", httpx.RouteMeta{
		Permission: "{{.PermPrefix}}.create",
		Request:    Create{{.ResourceTitle}}Request{},
	}, httpx.ValidatedHandler(v, 1<<20, h.create))
	r.Handle("GET", "/{{.Resource}}/{id}", httpx.RouteMeta{Permission: "{{.PermPrefix}}.read"}, h.get)
	r.Handle("GET", "/{{.Resource}}", httpx.RouteMeta{Permission: "{{.PermPrefix}}.list"}, h.list)
	r.Handle("PUT", "/{{.Resource}}/{id}", httpx.RouteMeta{
		Permission: "{{.PermPrefix}}.update",
		Request:    Update{{.ResourceTitle}}Request{},
	}, httpx.ValidatedHandler(v, 1<<20, h.update))
	r.Handle("DELETE", "/{{.Resource}}/{id}", httpx.RouteMeta{Permission: "{{.PermPrefix}}.deactivate"}, h.delete)
}

func (h *{{.ResourceTitle}}Handlers) create(w http.ResponseWriter, r *http.Request, in Create{{.ResourceTitle}}Request) {
	ctx := r.Context()
	actor, ok := database.ActorIDFrom(ctx)
	if !ok {
		http.Error(w, "authenticated actor missing", http.StatusInternalServerError)
		return
	}
	id := h.idgen.New()
	dto := {{.ResourceTitle}}DTO{ID: id.String(){{range .Fields}}, {{.GoName}}: in.{{.GoName}}{{end}}}
	err := h.tx.WithTenant(ctx, func(ctx context.Context, db database.TenantDB) error {
		if _, err := db.Exec(ctx, `INSERT INTO {{.Table}}
			(id, tenant_id{{range .Fields}}, {{.Name}}{{end}}, created_by)
			VALUES (@id, app_tenant_id(){{range .Fields}}, @{{.Name}}{{end}}, @actor)`,
			pgx.NamedArgs{
				"id": id, "actor": actor,
				{{- range .Fields}}
				"{{.Name}}": in.{{.GoName}},
				{{- end}}
			}); err != nil {
			return err
		}
		return h.outbox.Write(ctx, db, outbox.Event{
			Type: "{{.ModuleName}}.{{.Resource}}_created",
			Payload: map[string]any{"id": id},
		})
	})
	if err != nil {
		httpx.WriteError(ctx, w, err)
		return
	}
	httpx.WriteJSON(w, http.StatusCreated, httpx.OK(dto))
}

func (h *{{.ResourceTitle}}Handlers) get(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	id, err := uuid.Parse(r.PathValue("id"))
	if err != nil {
		http.Error(w, "invalid resource id", http.StatusBadRequest)
		return
	}
	var dto {{.ResourceTitle}}DTO
	err = h.tx.WithTenantRO(ctx, func(ctx context.Context, db database.TenantDB) error {
		return db.QueryRow(ctx, `SELECT id{{range .Fields}}, {{.Name}}{{end}}
			FROM {{.Table}} WHERE id = $1 AND status = 'active'`, id).
			Scan(&id{{range .Fields}}, &dto.{{.GoName}}{{end}})
	})
	if err != nil {
		// Absent and inactive rows are both RFC 9457 not-found (the query
		// filters status='active'); raw pgx.ErrNoRows would map to opaque 500.
		if errors.Is(err, pgx.ErrNoRows) {
			err = kerr.E(kerr.KindNotFound, "not_found", "{{.Resource}} not found")
		}
		httpx.WriteError(ctx, w, err)
		return
	}
	dto.ID = id.String()
	httpx.WriteJSON(w, http.StatusOK, httpx.OK(dto))
}

// list is a working keyset-paginated read: it is the canonical signed-cursor
// example (roadmap CA-2). Adjust the SELECT/scan for your columns.
func (h *{{.ResourceTitle}}Handlers) list(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	req, err := pagination.Parse(r.URL.Query().Get("per_page"), r.URL.Query().Get("cursor"),
		pagination.Defaults{PerPage: 50, MaxPerPage: 200})
	if err != nil {
		httpx.WriteError(ctx, w, err)
		return
	}

	page := pagination.CursorPage[{{.ResourceTitle}}DTO]{Items: []{{.ResourceTitle}}DTO{}}
	// createdAts/ids parallel page.Items so the cursor is minted from the last
	// RETURNED row, never the dropped lookahead row.
	var createdAts []time.Time
	var ids []uuid.UUID

	err = h.tx.WithTenantRO(ctx, func(ctx context.Context, db database.TenantDB) error {
		args := []any{req.Limit + 1}
		// KeysetClause verifies the cursor's sort signature and builds the
		// injection-safe "rows after the cursor" predicate ($1 is the limit).
		clause, cargs, _, cerr := filtering.KeysetClause(list{{.ResourceTitle}}Sort, req.Cursor, 2)
		if cerr != nil {
			return cerr
		}
		where := " WHERE status = 'active'"
		if clause != "" {
			where += " AND " + clause
			args = append(args, cargs...)
		}
		rows, qerr := db.Query(ctx,
			`SELECT id{{range .Fields}}, {{.Name}}{{end}}, created_at
			   FROM {{.Table}}`+where+`
			  ORDER BY created_at, id
			  LIMIT $1`, args...)
		if qerr != nil {
			return qerr
		}
		defer rows.Close()
		for rows.Next() {
			var dto {{.ResourceTitle}}DTO
			var id uuid.UUID
			var createdAt time.Time
			if serr := rows.Scan(&id{{range .Fields}}, &dto.{{.GoName}}{{end}}, &createdAt); serr != nil {
				return serr
			}
			dto.ID = id.String()
			page.Items = append(page.Items, dto)
			createdAts = append(createdAts, createdAt)
			ids = append(ids, id)
		}
		return rows.Err()
	})
	if err != nil {
		httpx.WriteError(ctx, w, err)
		return
	}

	if len(page.Items) > req.Limit {
		page.Items = page.Items[:req.Limit]
		page.HasMore = true
		next, cerr := filtering.NextCursor(list{{.ResourceTitle}}Sort, map[string]any{
			"created_at": createdAts[req.Limit-1], "id": ids[req.Limit-1],
		})
		if cerr != nil {
			httpx.WriteError(ctx, w, cerr)
			return
		}
		page.NextCursor = next
	}
	httpx.WriteJSON(w, http.StatusOK, httpx.OK(page))
}

func (h *{{.ResourceTitle}}Handlers) update(w http.ResponseWriter, r *http.Request, in Update{{.ResourceTitle}}Request) {
	ctx := r.Context()
	id, err := uuid.Parse(r.PathValue("id"))
	if err != nil {
		http.Error(w, "invalid resource id", http.StatusBadRequest)
		return
	}
	actor, ok := database.ActorIDFrom(ctx)
	if !ok {
		http.Error(w, "authenticated actor missing", http.StatusInternalServerError)
		return
	}
	dto := {{.ResourceTitle}}DTO{ID: id.String(){{range .Fields}}, {{.GoName}}: in.{{.GoName}}{{end}}}
	err = h.tx.WithTenant(ctx, func(ctx context.Context, db database.TenantDB) error {
		tag, err := db.Exec(ctx, `UPDATE {{.Table}}
			SET {{range .Fields}}{{.Name}} = @{{.Name}}, {{end}}version = version + 1,
				updated_at = now(), updated_by = @actor
			WHERE id = @id AND status = 'active'`,
			pgx.NamedArgs{
				"id": id, "actor": actor,
				{{- range .Fields}}
				"{{.Name}}": in.{{.GoName}},
				{{- end}}
			})
		if err != nil {
			return err
		}
		// Zero affected rows = absent or inactive resource: a valid request for
		// a missing row must be not-found, never a false 200.
		if tag.RowsAffected() == 0 {
			return kerr.E(kerr.KindNotFound, "not_found", "{{.Resource}} not found")
		}
		return nil
	})
	if err != nil {
		httpx.WriteError(ctx, w, err)
		return
	}
	httpx.WriteJSON(w, http.StatusOK, httpx.OK(dto))
}

func (h *{{.ResourceTitle}}Handlers) delete(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	id, err := uuid.Parse(r.PathValue("id"))
	if err != nil {
		http.Error(w, "invalid resource id", http.StatusBadRequest)
		return
	}
	actor, ok := database.ActorIDFrom(ctx)
	if !ok {
		http.Error(w, "authenticated actor missing", http.StatusInternalServerError)
		return
	}
	err = h.tx.WithTenant(ctx, func(ctx context.Context, db database.TenantDB) error {
		tag, err := db.Exec(ctx, `UPDATE {{.Table}}
			SET status = 'inactive', version = version + 1,
				updated_at = now(), updated_by = $2
			WHERE id = $1 AND status = 'active'`, id, actor)
		if err != nil {
			return err
		}
		// Zero affected rows = absent or already-inactive resource: not-found,
		// never a false 204.
		if tag.RowsAffected() == 0 {
			return kerr.E(kerr.KindNotFound, "not_found", "{{.Resource}} not found")
		}
		return nil
	})
	if err != nil {
		httpx.WriteError(ctx, w, err)
		return
	}
	w.WriteHeader(http.StatusNoContent)
}
