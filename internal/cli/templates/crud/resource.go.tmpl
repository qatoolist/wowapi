// {{.ResourceTitle}}DTO is the wire representation of a {{.Resource}}.
type {{.ResourceTitle}}DTO struct {
	ID string `json:"id"`
{{- range .Fields}}
	{{.GoName}} {{.GoType}} `json:"{{.Name}}"`
{{- end}}
}

// {{.ResourceTitle}}Handlers holds the collaborators every {{.Resource}} route needs.
type {{.ResourceTitle}}Handlers struct {
	tx database.TxManager
}

// list{{.ResourceTitle}}Sort is the fixed (created_at, id) keyset order. Building it
// through the filtering allowlist gives every cursor a sort-spec signature, so a
// forged or stale cursor is rejected loudly on decode (roadmap R7) instead of
// silently mis-paging.
var list{{.ResourceTitle}}Sort = func() filtering.Sort {
	s, err := filtering.ParseSort("created_at,id", filtering.SortAllowlist{
		"created_at": {Col: "created_at"},
		"id":         {Col: "id"},
	})
	if err != nil {
		panic("{{.Resource}}: invalid keyset sort: " + err.Error())
	}
	return s
}()

// Register{{.ResourceTitle}}Routes wires {{.Resource}} CRUD routes into mc.
func Register{{.ResourceTitle}}Routes(mc module.Context) {
	h := &{{.ResourceTitle}}Handlers{tx: mc.Tx()}
	r := mc.Routes()
	r.Handle("POST", "/{{.Resource}}", httpx.RouteMeta{Permission: "{{.PermPrefix}}.create"}, h.create)
	r.Handle("GET", "/{{.Resource}}/{id}", httpx.RouteMeta{Permission: "{{.PermPrefix}}.read"}, h.get)
	r.Handle("GET", "/{{.Resource}}", httpx.RouteMeta{Permission: "{{.PermPrefix}}.list"}, h.list)
	r.Handle("PUT", "/{{.Resource}}/{id}", httpx.RouteMeta{Permission: "{{.PermPrefix}}.update"}, h.update)
	r.Handle("DELETE", "/{{.Resource}}/{id}", httpx.RouteMeta{Permission: "{{.PermPrefix}}.delete"}, h.delete)
}

