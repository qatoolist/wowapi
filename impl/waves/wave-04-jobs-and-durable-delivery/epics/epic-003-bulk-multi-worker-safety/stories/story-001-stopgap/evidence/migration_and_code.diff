+// TestIntegrationBulkConcurrentProcessorRejected proves the DATA-04 T1 stopgap:
+// a second Process call against the same bulkID while a first is active is
+// rejected with ErrConcurrentProcessor, not silently allowed to race.
+func TestIntegrationBulkConcurrentProcessorRejected(t *testing.T) {
+	h := testkit.NewDB(t)
+	svc := bulk.New(model.UUIDv7())
+	tenant := uuid.New()
+	ctx := database.WithTenantID(context.Background(), tenant)
+
+	id := start(t, h, svc, ctx, payloads(item{Val: 1}, item{Val: 2}, item{Val: 3}))
+
+	unblock := make(chan struct{})
+	var started sync.WaitGroup
+	started.Add(1)
+	var signalOnce sync.Once
+
+	slowFunc := func(ctx context.Context, db database.TenantDB, payload []byte) error {
+		signalOnce.Do(started.Done)
+		<-unblock
+		return nil
+	}
+
+	var wg sync.WaitGroup
+	var firstErr error
+	var firstN int
+	wg.Add(1)
+	go func() {
+		defer wg.Done()
+		firstN, firstErr = svc.Process(context.Background(), h.TxM, tenant, id, 0, slowFunc)
+	}()
+
+	started.Wait() // first processor is now inside an item
+
+	var secondErr error
+	wg.Add(1)
+	go func() {
+		defer wg.Done()
+		_, secondErr = svc.Process(context.Background(), h.TxM, tenant, id, 0, okFunc)
+	}()
+
+	// Give the second processor time to attempt acquisition and be rejected.
+	// It should return quickly because the lock check is a single UPDATE.
+	for i := 0; i < 50 && secondErr == nil; i++ {
+		time.Sleep(10 * time.Millisecond)
+	}
+	if secondErr == nil {
+		t.Fatal("second processor was not rejected while first is active")
+	}
+	if kerr.KindOf(secondErr) != kerr.KindConflict {
+		t.Fatalf("second processor error kind = %v, want KindConflict (err=%v)", kerr.KindOf(secondErr), secondErr)
+	}
+
+	close(unblock)
+	wg.Wait()
+
+	if firstErr != nil {
+		t.Fatalf("first processor failed: %v", firstErr)
+	}
+	if firstN != 3 {
+		t.Fatalf("first processor processed %d, want 3", firstN)
+	}
+	p := progress(t, h, svc, ctx, id)
+	if p.Done != 3 || p.Pending != 0 || p.Status != "completed" {
+		t.Fatalf("progress = %+v, want Done3/Pending0/completed", p)
+	}
+}
