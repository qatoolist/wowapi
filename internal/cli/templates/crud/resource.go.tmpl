// list is a working keyset-paginated read: it is the canonical signed-cursor
// example (roadmap CA-2). Adjust the SELECT/scan for your columns.
func (h *{{.ResourceTitle}}Handlers) list(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	req, err := pagination.Parse(r.URL.Query().Get("per_page"), r.URL.Query().Get("cursor"),
		pagination.Defaults{PerPage: 50, MaxPerPage: 200})
	if err != nil {
		httpx.WriteError(ctx, w, err)
		return
	}

	page := pagination.CursorPage[{{.ResourceTitle}}DTO]{Items: []{{.ResourceTitle}}DTO{}}
	// createdAts/ids parallel page.Items so the cursor is minted from the last
	// RETURNED row, never the dropped lookahead row.
	var createdAts []time.Time
	var ids []uuid.UUID

	err = h.tx.WithTenantRO(ctx, func(ctx context.Context, db database.TenantDB) error {
		args := []any{req.Limit + 1}
		// KeysetClause verifies the cursor's sort signature and builds the
		// injection-safe "rows after the cursor" predicate ($1 is the limit).
		clause, cargs, _, cerr := filtering.KeysetClause(list{{.ResourceTitle}}Sort, req.Cursor, 2)
		if cerr != nil {
			return cerr
		}
		where := ""
		if clause != "" {
			where = " WHERE " + clause
			args = append(args, cargs...)
		}
		rows, qerr := db.Query(ctx,
			`SELECT id{{range .Fields}}, {{.Name}}{{end}}, created_at
			   FROM {{.Table}}`+where+`
			  ORDER BY created_at, id
			  LIMIT $1`, args...)
		if qerr != nil {
			return qerr
		}
		defer rows.Close()
		for rows.Next() {
			var dto {{.ResourceTitle}}DTO
			var id uuid.UUID
			var createdAt time.Time
			if serr := rows.Scan(&id{{range .Fields}}, &dto.{{.GoName}}{{end}}, &createdAt); serr != nil {
				return serr
			}
			dto.ID = id.String()
			page.Items = append(page.Items, dto)
			createdAts = append(createdAts, createdAt)
			ids = append(ids, id)
		}
		return rows.Err()
	})
	if err != nil {
		httpx.WriteError(ctx, w, err)
		return
	}

	if len(page.Items) > req.Limit {
		page.Items = page.Items[:req.Limit]
		page.HasMore = true
		next, cerr := filtering.NextCursor(list{{.ResourceTitle}}Sort, map[string]any{
			"created_at": createdAts[req.Limit-1], "id": ids[req.Limit-1],
		})
		if cerr != nil {
			httpx.WriteError(ctx, w, cerr)
			return
		}
		page.NextCursor = next
	}
	httpx.WriteJSON(w, http.StatusOK, httpx.OK(page))
}

