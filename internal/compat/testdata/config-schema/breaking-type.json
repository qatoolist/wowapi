{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "environment": {"type": "string", "enum": ["development", "production"]},
    "database": {
      "type": "object",
      "properties": {
        "host": {"type": "string"},
        "port": {"type": "string"}
      },
      "required": ["host"]
    }
  }
}
