# Base configuration for {{.Name}}.
# All environments load this file first; overlay files (<env>.yaml) narrow it.
# DO NOT set environment here — each overlay must declare its own.
# Reference: docs/blueprint/12-configuration-and-deployment.md

schema_version: 1

http:
  addr: ":8080"
  # Connection-level server timeouts (safe defaults; 0 = unlimited and is
  # refused in prod). read_header/read/write bound a single request's header,
  # full-request, and response phases; idle bounds keep-alive gaps between
  # requests. request_timeout is the per-request HANDLER budget on top.
  read_header_timeout: 5s
  read_timeout: 30s
  write_timeout: 60s
  idle_timeout: 120s
  request_timeout: 30s
  max_body_bytes: 1048576

log:
  level: info
  format: json

db:
  # DSN is NOT set here — define it in the env overlay (configs/<env>.yaml)
  # as a secretref://env/<VAR> reference, or pass DATABASE_URL at runtime.
  # See configs/local.yaml for the local-dev pattern.
  max_conns: 16
  query_timeout: 5s

# i18n — localization catalog loading (GAP-001B). PRODUCT-owned section
# (appcfg.Config.I18n), like auth/storage/security below: the prebuilt wowapi
# binary's framework-only `config validate` fallback does not know these keys,
# so they ship commented; the values shown are the compiled-in defaults (the
# zero value is fully valid — locales/ still loads with no config section).
# The framework's English defaults are always embedded; these settings add
# product translations on top. locales/ (YAML + JSON) is loaded as a sanctioned
# framework-override source, so a locales/<locale>/kernel.yaml key overrides
# the embedded framework default; internal/i18n/catalogs holds optional
# compiled Go bundles. cmd/api, cmd/worker, AND cmd/migrate load these same
# sources before boot completes. Validate catalogs with `wowapi i18n validate
# --supported en,mr`.
# i18n:
#   default_locale: en
#   supported_locales: [en, mr]
#   locales_dir: locales
#   go_bundles: true

# auth.oidc — user (OIDC/JWT bearer) authentication. Leave unset to keep the
# user leg deny-by-default (only API keys authenticate); set issuer + audience
# (and optionally jwks_uri) in an env overlay to enable it. When jwks_uri is
# empty it is discovered from the issuer's /.well-known/openid-configuration.
# auth:
#   oidc:
#     issuer: "https://idp.example.com/"
#     audience: "{{.Name}}"
#     jwks_uri: ""

# security — SecurityProfile (framework-owned; docs/blueprint/07 §1, backlog
# B7). Default is the "api" profile and reproduces exactly today's behavior
# (bearer/API-key auth, CSRF-free by contract, CORS allowlist, RLS guard) —
# leaving this section out, as below, is identical to setting profile: api.
# Only switch to "browser" if this product serves a cookie/session browser
# client; doing so wires CSRF token enforcement (double-submit cookie) on
# every state-changing request plus SameSite cookie defaults and a CSP header
# profile for HTML. `wowapi config validate` rejects an incoherent browser
# profile (e.g. missing csrf.cookie_name).
# security:
#   profile: browser
#   csrf:
#     cookie_name: "csrf_token"
#     header_name: "X-CSRF-Token"
#     field_name: "csrf_token"
#   cookie:
#     same_site: lax
#     secure: true

# storage — optional S3/MinIO object storage for the document framework
# (adapters/storage/s3). Leave endpoint unset to keep object storage disabled
# (app.Boot fails closed if a module registers a document class with no
# storage adapter wired). access_key/secret_key MUST be secretref:// references,
# never inline values. create_bucket is for local/dev overlays only.
# storage:
#   endpoint: "localhost:9000"
#   bucket: "{{.DBName}}-docs"
#   region: ""
#   access_key: "secretref://env/S3_ACCESS_KEY"
#   secret_key: "secretref://env/S3_SECRET_KEY"
#   use_ssl: false
#   presign_ttl: 15m
#   create_bucket: false

# privileged — per-module allow-list widening for mc.Privileged() (kernel/privileged).
# By default a module may only Grant/Revoke relationship types and activate rule
# keys prefixed with its own name ("<module>."). Add an entry here ONLY when a
# module has a legitimate reason to manage a kernel- or another-namespace-owned
# key (e.g. a "committee" module sanctioned to grant the kernel "core.owner_of"
# relationship type). SECURITY: every entry must be a concrete, fully-spelled
# key — wildcards/glob syntax ("*", "?", "[...]") and empty entries are REJECTED
# at boot (fail closed). See docs/user-guide/modules.md, "Privileged services".
# privileged:
#   committee:
#     allow_rel_types:
#       - "core.owner_of"
#     allow_rule_keys:
#       - "policy.retention.days"
# concurrency — capacity budget + HTTP backpressure (see docs/user-guide/configuration.md
# "Concurrency: capacity budget + backpressure"). Every field below defaults to 0/advisory,
# which is a complete no-op: no in-flight limiter is installed and the capacity-budget check
# is skipped until you declare a deployment shape. Uncomment and size once you know your
# replica count and pool sizes, then run `wowapi config capacity` to confirm the shape fits
# under db.max_conns before flipping capacity_mode to enforced.
# concurrency:
#   http_max_in_flight: 256      # 0 disables the backpressure middleware (default)
#   replicas: 2                  # process replicas of this deployment sharing the database
#   runtime_pool_max: 16         # runtime (app_rt) pool max_conns per replica
#   platform_pool_max: 8         # platform (app_platform) pool max_conns per replica
#   migrate_pool_max: 2          # migrate process pool max_conns (counted once, not per replica)
#   reserved_admin: 4            # connections reserved for admin/operator access
#   capacity_mode: advisory      # advisory (warn only, default) | enforced (fail boot)
#   overload:
#     api_status: 503            # 503 or 429
#     retry_after: 2s
