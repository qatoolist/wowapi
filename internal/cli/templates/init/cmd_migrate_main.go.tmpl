// Command migrate runs database migrations for {{.Name}}.
//
// Usage: migrate [up|down]   (default "up")
//
//	up    apply kernel then module migrations (forward, expand-contract), then
//	      sync the merged module seed catalog (permissions, roles, resource
//	      types, relationship types) idempotently, then sync the rule
//	      registry's definitions (rule_definitions) idempotently. Without the
//	      seed step the catalogs stay empty and every authorization check
//	      denies (GAP-003); without the rule-definition step, any registered
//	      rule point fails rule_versions.rule_key's FK until synced (GAP-007) —
//	      see docs/user-guide/database-migrations.md#seeds and
//	      docs/user-guide/database-migrations.md#rule-definitions.
//	down  roll ALL migrations back to version 0 (full reset). Guarded: refuses
//	      unless the environment is local or dev — production rollback is an
//	      expand-contract anti-pattern (see docs/blueprint/12) and this runner
//	      offers no stepwise down. Use forward migrations to change prod schema.
package main

import (
	"context"
	"fmt"
	"os"
	"sort"
	"time"

	"github.com/qatoolist/wowapi/v2/app"
	"github.com/qatoolist/wowapi/v2/kernel"
	"github.com/qatoolist/wowapi/v2/kernel/config"
	"github.com/qatoolist/wowapi/v2/kernel/database"
	"github.com/qatoolist/wowapi/v2/kernel/logging"
	"github.com/qatoolist/wowapi/v2/kernel/rules"
	"github.com/qatoolist/wowapi/v2/kernel/storage"
	"github.com/qatoolist/wowapi/v2/kernel/seeds"
	"github.com/qatoolist/wowapi/v2/migrations"

	"{{.Module}}/internal/appcfg"
	"{{.Module}}/internal/wire"
)

func main() {
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Minute)
	defer cancel()
	if err := run(ctx, os.Args[1:]); err != nil {
		fmt.Fprintf(os.Stderr, "{{.Name}}: migrate: %v\n", err)
		os.Exit(1)
	}
}

func run(ctx context.Context, argv []string) error {
	direction := "up"
	if len(argv) > 0 {
		direction = argv[0]
	}
	if direction != "up" && direction != "down" {
		return fmt.Errorf("unknown command %q (want up|down)", direction)
	}

	// Load configuration FAIL-CLOSED: a malformed config, an invalid environment,
	// or an unresolvable secret aborts the migrate rather than silently applying
	// DDL under compiled defaults. (config.Load needs no files on disk — env vars
	// alone are fine — so a bare container with only DATABASE_URL still loads.)
	cfg, err := loadConfig()
	if err != nil {
		return fmt.Errorf("config: %w", err)
	}

	log, err := logging.New(os.Stderr, cfg.Log)
	if err != nil {
		return fmt.Errorf("logger: %w", err)
	}

	// A full reset is destructive and must never touch a shared/production DB.
	if direction == "down" && cfg.Environment != config.EnvLocal && cfg.Environment != config.EnvDev {
		return fmt.Errorf("refusing to reset the database in environment %q — migrate down performs a FULL rollback to version 0 and is permitted only in local/dev; change prod schema with forward (expand-contract) migrations", cfg.Environment)
	}

	// Resolve DSN: prefer db.migrate_dsn, then db.dsn, then DATABASE_URL.
	dsn := cfg.DB.MigrateDSN.Reveal()
	if dsn == "" {
		dsn = cfg.DB.DSN.Reveal()
	}
	if dsn == "" {
		dsn = os.Getenv("DATABASE_URL")
	}
	if dsn == "" {
		return fmt.Errorf("DSN required: set DATABASE_URL or configure db.migrate_dsn in configs/")
	}

	// Migrate pool: no role constraint — the DSN user owns the schema.
	pool, err := database.NewPool(ctx, dsn, cfg.DB)
	if err != nil {
		return fmt.Errorf("db pool: %w", err)
	}
	defer pool.Close()

	// Boot the app to collect module migration sets. Boot wires only in-memory
	// registries during Register, so it succeeds regardless of DB state. The migrate
	// process connects with DDL (privileged) credentials by design and never serves
	// tenant traffic, so it opts out of the runtime RLS-enforcement check
	// (SkipRLSEnforcementCheck) — that check is for the tenant-serving api/worker
	// runtime pool, which must be a non-privileged app_rt role.
	txm := database.NewManager(pool, cfg.DB)
	k, err := kernel.New(cfg.Framework, log, kernel.Deps{Pool: pool, Tx: txm, Storage: storage.NewMemory()})
	if err != nil {
		return fmt.Errorf("kernel: %w", err)
	}
	// Load the SAME i18n catalog sources as cmd/api and cmd/worker: migrate boots
	// the app (to collect migration sets) through the identical lifecycle, so a
	// broken catalog fails migrate too — the whole product shares one i18n contract.
	i18nLayers, err := cfg.I18n.Layers()
	if err != nil {
		return fmt.Errorf("i18n: %w", err)
	}
	a := app.New()
	a.Register(wire.Modules()...)
	booted, err := a.Boot(ctx, k, nil, app.SkipRLSEnforcementCheck(), app.WithI18nLayers(i18nLayers...))
	if err != nil {
		return fmt.Errorf("boot: %w", err)
	}

	// Module migration sources in stable alphabetical order, from the
	// boot-validated view (RuntimeMigrations) — the informational Migrations
	// field could have been reassigned after boot.
	moduleMigrations := booted.RuntimeMigrations()
	names := make([]string, 0, len(moduleMigrations))
	for name := range moduleMigrations {
		names = append(names, name)
	}
	sort.Strings(names)

	if direction == "down" {
		// Reverse of up: reset modules first (reverse alphabetical), then the kernel,
		// so foreign keys onto kernel tables are gone before the kernel schema drops.
		for i := len(names) - 1; i >= 0; i-- {
			name := names[i]
			v, err := database.MigrateReset(ctx, pool, moduleMigrations[name], name)
			if err != nil {
				return fmt.Errorf("module %q reset: %w", name, err)
			}
			log.InfoContext(ctx, "module migrations reset", "module", name, "version", v)
		}
		v, err := database.MigrateReset(ctx, pool, migrations.Kernel(), migrations.SourceName)
		if err != nil {
			return fmt.Errorf("kernel reset: %w", err)
		}
		log.InfoContext(ctx, "kernel migrations reset", "source", migrations.SourceName, "version", v)
		return nil
	}

	// up: kernel migrations first (blueprint 03 §5 ordering contract), then modules.
	res, err := database.Migrate(ctx, pool, migrations.Kernel(), migrations.SourceName)
	if err != nil {
		return fmt.Errorf("kernel migrations: %w", err)
	}
	log.InfoContext(ctx, "kernel migrations applied",
		"source", migrations.SourceName, "applied", res.Applied, "version", res.Version)

	for _, name := range names {
		r, err := database.Migrate(ctx, pool, moduleMigrations[name], name)
		if err != nil {
			return fmt.Errorf("module %q migrations: %w", name, err)
		}
		log.InfoContext(ctx, "module migrations applied",
			"module", name, "applied", r.Applied, "version", r.Version)
	}

	// Seed sync (blueprint 06 §2 lifecycle SeedSync): upsert the merged module
	// catalogs (permissions, roles, resource types, relationship types)
	// idempotently. This is the deploy point that already holds a privileged
	// connection; without it the DB catalogs stay empty — every authorization
	// check denies and resource-mirror writes fail their FK (GAP-003). No
	// invalidator is passed: this process holds no long-lived authz cache (it
	// exits immediately after migrating), unlike the api/worker runtime.
	// RuntimeSeeds is the boot-validated catalog; the informational Seeds
	// field could have been reassigned or mutated after boot.
	seedReport, err := seeds.Apply(ctx, pool, booted.RuntimeSeeds(), seeds.ApplyOptions{Actor: "migrate"})
	if err != nil {
		return fmt.Errorf("seed sync: %w", err)
	}
	log.InfoContext(ctx, "seed catalogs synced",
		"modules", len(names),
		"outcome", seedReport.Outcome,
		"hash", seedReport.Hash)

	// Rule-definition sync (GAP-007, mirrors seed sync's lifecycle position
	// exactly): upsert every module-registered rule Point into rule_definitions
	// idempotently. Runs on the same privileged migrate pool, right after seed
	// sync and before anything proposes/activates a rule_versions row for a
	// key — rule_versions.rule_key FKs rule_definitions, so a registered point
	// with no synced definition would fail Propose with a foreign-key error
	// the first time a product tried to use it.
	if err := rules.SyncDefinitions(ctx, pool, k.Rules); err != nil {
		return fmt.Errorf("rule definition sync: %w", err)
	}
	log.InfoContext(ctx, "rule definitions synced", "keys", len(k.Rules.Keys()))
	return nil
}

// loadConfig reads the layered configuration (configs/base.yaml, configs/<APP_ENV>.yaml,
// then WOWAPI__ env vars) with secretref:// values resolved via the env secret
// provider. It fails closed: any load error is returned to the caller. No files are
// required on disk (env vars alone suffice), but environment must be set — so a bare
// container needs WOWAPI__ENVIRONMENT (plus a DSN), never a silent default.
//
// It loads the COMPOSED product config (appcfg.Config), not bare
// config.Framework: the strict loader rejects unknown keys, so product-owned
// sections in the overlays (auth.*, storage.*) would otherwise abort the
// migrate while the api/worker accept the very same file. Only the promoted
// framework fields are used here; migrate never touches object storage.
func loadConfig() (appcfg.Config, error) {
	cfg, _, err := appcfg.Load()
	return cfg, err
}
