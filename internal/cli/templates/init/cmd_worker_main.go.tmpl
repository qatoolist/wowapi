// Command worker is the background worker for {{.Name}}.
package main

import (
	"context"
	"fmt"
	"net/http"
	"os"
	"os/signal"
	"syscall"

	promadapter "github.com/qatoolist/wowapi/adapters/metrics/prometheus"
	s3adapter "github.com/qatoolist/wowapi/adapters/storage/s3"
	oteladapter "github.com/qatoolist/wowapi/adapters/tracing/otel"
	"github.com/qatoolist/wowapi/app"
	"github.com/qatoolist/wowapi/kernel"
	"github.com/qatoolist/wowapi/kernel/database"
	"github.com/qatoolist/wowapi/kernel/logging"
	"github.com/qatoolist/wowapi/kernel/observability"
	"github.com/qatoolist/wowapi/kernel/storage"

	"{{.Module}}/internal/appcfg"
	"{{.Module}}/internal/wire"
)

func main() {
	ctx, cancel := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)
	defer cancel()
	if err := run(ctx); err != nil {
		fmt.Fprintf(os.Stderr, "{{.Name}}: worker: %v\n", err)
		os.Exit(1)
	}
}

func run(ctx context.Context) error {
	cfg, fp, err := appcfg.Load()
	if err != nil {
		return fmt.Errorf("config: %w", err)
	}

	log, err := logging.New(os.Stderr, cfg.Log)
	if err != nil {
		return fmt.Errorf("logger: %w", err)
	}
	logging.LogStartup(log, "worker", cfg.Environment, fp)

	dsn := cfg.DB.DSN.Reveal()
	if dsn == "" {
		dsn = os.Getenv("DATABASE_URL")
	}
	if dsn == "" {
		return fmt.Errorf("db.dsn required: set db.dsn in configs/ via secretref://env/DATABASE_URL, or export DATABASE_URL")
	}

	// Runtime pool: app_rt with RLS enforcement (SEC-11/SEC-12).
	pool, err := database.NewPool(ctx, dsn, cfg.DB,
		database.WithSetRole("app_rt"),
		database.WithConnRLSGuard(),
	)
	if err != nil {
		return fmt.Errorf("db pool (runtime): %w", err)
	}
	defer pool.Close()

	// Platform pool for the outbox relay, job runner, and scheduler (cross-tenant
	// kernel work). This MUST use a dedicated app_platform login (db.platform_dsn),
	// never the runtime DSN: reusing app_rt + SET ROLE app_platform would require
	// app_rt to be a (cluster-global) member of app_platform and collapse runtime/
	// platform privilege separation (CF-1). Fail closed rather than silently escalate.
	platformDSN := cfg.DB.PlatformDSN.Reveal()
	if platformDSN == "" {
		return fmt.Errorf("db.platform_dsn is required: the platform pool needs a dedicated app_platform " +
			"login (set db.platform_dsn, e.g. secretref://env/PLATFORM_URL). Reusing the runtime DSN would " +
			"require app_rt to be a member of app_platform and defeat runtime/platform privilege separation")
	}
	platformPool, err := database.NewPool(ctx, platformDSN, cfg.DB,
		database.WithSetRole("app_platform"),
		// Reject a superuser/BYPASSRLS platform DSN at connect time: app_platform
		// reads cross-tenant via permissive RLS policies, not by bypassing RLS.
		database.WithConnRLSGuard(),
	)
	if err != nil {
		return fmt.Errorf("db pool (platform): %w", err)
	}
	defer platformPool.Close()

	txm := database.NewManager(pool, cfg.DB,
		database.WithRole("app_rt"),
		database.WithRLSGuard(),
	)

	// Metrics: the worker exports scheduler/sweeper lag, webhook breaker state,
	// and (once wired) DLQ depth. Scrape it on an internal listener (default
	// :9090, override with WORKER_METRICS_ADDR) — never expose it publicly.
	metrics := promadapter.New()
	metrics.SetGauge("wowapi_config_fingerprint_info", 1,
		map[string]string{"fingerprint": fp.Short()})

	// Tracing: the relay continues each event's originating request trace across
	// the async boundary when telemetry.trace_sample_ratio > 0 (roadmap O1/CA-9).
	tracer := observability.NoOpTracer
	if cfg.Telemetry.TraceSampleRatio > 0 {
		ot, terr := oteladapter.NewOTLP(ctx, cfg.Telemetry.TraceSampleRatio)
		if terr != nil {
			log.WarnContext(ctx, "tracing disabled: OTLP exporter init failed", "err", terr)
		} else {
			tracer = ot
			defer func() { _ = ot.Shutdown(context.WithoutCancel(ctx)) }()
		}
	}

	// Object storage (optional, mirrors cmd/api): wired only when
	// storage.endpoint is configured; otherwise Deps.Storage stays nil and
	// app.Boot fails closed if a module registers a document class. The
	// worker needs the same adapter as the api — retention voiding and
	// document jobs touch the store from this process.
	var store storage.Adapter
	if cfg.Storage.Enabled() {
		s3a, serr := s3adapter.New(ctx, s3adapter.Config{
			Endpoint:     cfg.Storage.Endpoint,
			Bucket:       cfg.Storage.Bucket,
			Region:       cfg.Storage.Region,
			AccessKey:    cfg.Storage.AccessKey.Reveal(),
			SecretKey:    cfg.Storage.SecretKey.Reveal(),
			UseSSL:       cfg.Storage.UseSSL,
			PresignTTL:   cfg.Storage.PresignTTL,
			CreateBucket: cfg.Storage.CreateBucket,
		})
		if serr != nil {
			return fmt.Errorf("storage: %w", serr)
		}
		store = s3a
	}

	k, err := kernel.New(cfg.Framework, log, kernel.Deps{
		Pool:     pool,
		Platform: platformPool,
		Tx:       txm,
		Storage:  store,
		Metrics:  metrics,
		Tracer:   tracer,
	})
	if err != nil {
		return fmt.Errorf("kernel: %w", err)
	}

	// Load the SAME i18n catalog sources as cmd/api and cmd/migrate so all three
	// binaries share one localization lifecycle (the worker localizes strings in
	// notifications/jobs the same way the API localizes responses).
	i18nLayers, err := cfg.I18n.Layers()
	if err != nil {
		return fmt.Errorf("i18n: %w", err)
	}

	a := app.New()
	a.Register(wire.Modules()...)
	booted, err := a.Boot(ctx, k, cfg.Modules, app.WithI18nLayers(i18nLayers...))
	if err != nil {
		return fmt.Errorf("boot: %w", err)
	}

	// Internal metrics endpoint. Serves only while the worker runs; shut down
	// when the process context is cancelled.
	metricsAddr := os.Getenv("WORKER_METRICS_ADDR")
	if metricsAddr == "" {
		metricsAddr = ":9090"
	}
	metricsMux := http.NewServeMux()
	metricsMux.Handle("/metrics", metrics.Handler())
	metricsSrv := &http.Server{Addr: metricsAddr, Handler: metricsMux, ReadHeaderTimeout: cfg.HTTP.ReadHeaderTimeout}
	go func() {
		if err := metricsSrv.ListenAndServe(); err != nil && err != http.ErrServerClosed {
			log.ErrorContext(ctx, "worker metrics server error", "err", err)
		}
	}()
	defer func() { _ = metricsSrv.Shutdown(context.WithoutCancel(ctx)) }()

	return app.StartWorker(ctx, booted, app.WorkerConfigOpts{})
}
