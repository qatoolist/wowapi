// {{.Title}} is generated {{.Kind}} wiring for the {{.ModuleName}} module.
package {{.Package}}

import (
{{- if eq .Kind "rule"}}
	"encoding/json"

	"{{.FrameworkModule}}/kernel/rules"
{{- else if eq .Kind "workflow"}}
	"{{.FrameworkModule}}/kernel/workflow"
{{- else if eq .Kind "event-handler"}}
	"context"

	"{{.FrameworkModule}}/kernel/database"
	"{{.FrameworkModule}}/kernel/outbox"
{{- else if eq .Kind "recurring-job"}}
	"context"
	"time"

	"{{.FrameworkModule}}/kernel/database"
{{- else if eq .Kind "document-flow"}}
	"{{.FrameworkModule}}/foundation/document"
{{- else if eq .Kind "notification"}}
	"{{.FrameworkModule}}/foundation/notify"
{{- else if eq .Kind "webhook"}}
	"context"
	"encoding/json"
	"io"
	"net/http"

	"github.com/google/uuid"

	"{{.FrameworkModule}}/foundation/webhook"
	"{{.FrameworkModule}}/kernel/database"
	"{{.FrameworkModule}}/kernel/httpx"
{{- end}}
	"{{.FrameworkModule}}/module"
)

func init() {
	registerGenerated(func(mc module.Context) error {
{{- if eq .Kind "rule"}}
		mc.Rules().Register("{{.ModuleName}}", rules.Point{
			Key:           "{{.ModuleName}}.generated.{{.Name}}",
			Module:        "{{.ModuleName}}",
			ValueSchema:   json.RawMessage(`{"type":"boolean"}`),
			Default:       json.RawMessage(`false`),
			AllowedScopes: []rules.ScopeKind{rules.ScopeTenant},
			Description:   "Generated {{.Title}} rule point.",
		})
		return nil
{{- else if eq .Kind "workflow"}}
		return mc.Workflows().RegisterDefinition(workflow.Definition{
			Key:         "{{.ModuleName}}.{{.Name}}",
			Version:     1,
			AppliesTo:   "{{.ModuleName}}.resource",
			InitialStep: "complete",
			Steps: map[string]workflow.Step{
				"complete": {Type: workflow.StepTerminal, Outcome: "completed"},
			},
		})
{{- else if eq .Kind "event-handler"}}
		mc.Events().Subscribe("{{.ModuleName}}.{{.Name}}", "{{.ModuleName}}.{{.Name}}", handle{{.Title}}Event)
		return nil
{{- else if eq .Kind "recurring-job"}}
		mc.RecurringJob("{{.Name}}", time.Hour, run{{.Title}}RecurringJob)
		return nil
{{- else if eq .Kind "document-flow"}}
		mc.DocumentClasses().Register("{{.ModuleName}}", document.Class{
			Key:                "{{.ModuleName}}.{{.Name}}",
			DefaultSensitivity: document.SensitivityInternal,
			MaxBytes:           10 << 20,
			AllowedMIME:        []string{"application/pdf", "text/plain"},
		})
		return nil
{{- else if eq .Kind "notification"}}
		mc.NotifyTemplates().Register("{{.ModuleName}}", notify.TemplateSpec{
			Key:      "{{.ModuleName}}.generated.{{.Name}}",
			Vars:     []string{"RecipientName"},
			Channels: []string{string(notify.ChannelEmail), string(notify.ChannelInApp)},
		})
		return nil
{{- else if eq .Kind "webhook"}}
		const providerKey = "{{.ModuleName}}.{{.Name}}"
		mc.Webhooks().RegisterVerifier(providerKey, webhook.TimestampedHMACVerifier{})
		mc.Webhooks().RegisterHandler(providerKey, handle{{.Title}}Webhook)
		tx, service := mc.Tx(), mc.Webhooks()
		mc.Routes().Handle(http.MethodPost,
			"/webhooks/{{.ModuleName}}/{{.Name}}/{tenant_id}/{endpoint_id}",
			httpx.RouteMeta{Public: true, Request: json.RawMessage{}},
			inbound{{.Title}}Webhook(tx, service),
		)
		return nil
{{- end}}
	})
}
{{- if eq .Kind "event-handler"}}

func handle{{.Title}}Event(context.Context, database.TenantDB, outbox.DispatchedEvent) error {
	return nil
}
{{- else if eq .Kind "recurring-job"}}

func run{{.Title}}RecurringJob(context.Context, database.TenantDB) error {
	return nil
}
{{- else if eq .Kind "webhook"}}

func handle{{.Title}}Webhook(context.Context, database.TenantDB, webhook.Event) error {
	return nil
}

func inbound{{.Title}}Webhook(tx database.TxManager, service *webhook.Service) http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		tenantID, err := uuid.Parse(r.PathValue("tenant_id"))
		if err != nil || tenantID == uuid.Nil {
			http.Error(w, "invalid tenant id", http.StatusBadRequest)
			return
		}
		endpointID, err := uuid.Parse(r.PathValue("endpoint_id"))
		if err != nil || endpointID == uuid.Nil {
			http.Error(w, "invalid endpoint id", http.StatusBadRequest)
			return
		}
		body, err := io.ReadAll(http.MaxBytesReader(w, r.Body, 1<<20))
		if err != nil {
			http.Error(w, "invalid webhook body", http.StatusBadRequest)
			return
		}
		headers := make(map[string]string, len(r.Header))
		for key := range r.Header {
			headers[key] = r.Header.Get(key)
		}
		ctx := database.WithTenantID(r.Context(), tenantID)
		err = tx.WithTenant(ctx, func(ctx context.Context, db database.TenantDB) error {
			return service.HandleInbound(ctx, db, webhook.InboundIn{
				EndpointID: endpointID, ProviderKey: "{{.ModuleName}}.{{.Name}}",
				RawBody: body, Headers: headers, EventType: "{{.ModuleName}}.{{.Name}}",
			})
		})
		if err != nil {
			httpx.WriteError(r.Context(), w, err)
			return
		}
		w.WriteHeader(http.StatusAccepted)
	}
}
{{- end}}
